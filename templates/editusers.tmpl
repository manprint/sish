{{ define "editusers" }}
{{ template "header" .}}
<div class="row">
    <div class="col table-responsive">
        <h2>Edit Auth Users YAML</h2>
        <p>Directory: <code data-bind="text: usersDirectory"></code></p>
        <table id="editusers-table" class="table table-hover">
            <thead class="thead-dark">
                <tr>
                    <th scope="col">File</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody data-bind="foreach: files">
                <tr>
                    <td data-bind="text: $data"></td>
                    <td>
                        <a style="text-transform: none; color: white;" class="btn btn-info btn-sm mr-2" href="javascript:void(0);" data-bind="click: function(){ $root.viewFile($data); }">View</a>
                        <a style="text-transform: none; color: white;" class="btn btn-primary btn-sm" href="javascript:void(0);" data-bind="click: function(){ $root.editFile($data); }">Edit</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="viewUsersFileModal" tabindex="-1" role="dialog" aria-labelledby="viewUsersFileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewUsersFileModalLabel">View File</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <pre id="viewUsersFileModalBody" class="mb-0" style="white-space: pre-wrap;"></pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editUsersFileModal" tabindex="-1" role="dialog" aria-labelledby="editUsersFileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editUsersFileModalLabel">Edit File</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="editUsersValidationResult" class="alert d-none" role="alert"></div>
                <textarea id="editUsersFileModalBody" class="form-control" rows="18" style="font-family: monospace;"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-info" data-bind="click: validateCurrentFile">Validate</button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" data-bind="click: saveCurrentFile">Save</button>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var editUsersView = {
        files: ko.observableArray([]),
        usersDirectory: ko.observable(''),
        currentFile: ko.observable('')
    };

    editUsersView.getToken = function() {
        var params = new URLSearchParams(window.location.search);
        return params.get('x-authorization') || '';
    };

    editUsersView.apiUrl = function(path) {
        var token = this.getToken();
        if (!token) {
            return path;
        }

        var separator = path.indexOf('?') === -1 ? '?' : '&';
        return path + separator + 'x-authorization=' + encodeURIComponent(token);
    };

    editUsersView.showValidation = function(message, isValid) {
        var box = $('#editUsersValidationResult');
        box.removeClass('d-none alert-success alert-danger');
        box.addClass(isValid ? 'alert-success' : 'alert-danger');
        box.text(message);
    };

    editUsersView.clearValidation = function() {
        $('#editUsersValidationResult').addClass('d-none').removeClass('alert-success alert-danger').text('');
    };

    editUsersView.loadFiles = function() {
        $.getJSON(this.apiUrl('/_sish/api/editusers/files'), function(data) {
            editUsersView.files.removeAll();
            for (var i = 0; i < data.files.length; i++) {
                editUsersView.files.push(data.files[i]);
            }
            editUsersView.usersDirectory(data.usersDirectory || '');
        }).fail(function(xhr) {
            alert('Unable to load files: ' + (xhr.responseText || xhr.statusText));
        });
    };

    editUsersView.viewFile = function(filePath) {
        $.getJSON(this.apiUrl('/_sish/api/editusers/file?file=' + encodeURIComponent(filePath)), function(data) {
            $('#viewUsersFileModalLabel').text('View - ' + data.file);
            $('#viewUsersFileModalBody').text(data.content || '');
            $('#viewUsersFileModal').modal('show');
        }).fail(function(xhr) {
            alert('Unable to load file: ' + (xhr.responseText || xhr.statusText));
        });
    };

    editUsersView.editFile = function(filePath) {
        $.getJSON(this.apiUrl('/_sish/api/editusers/file?file=' + encodeURIComponent(filePath)), function(data) {
            editUsersView.currentFile(data.file || filePath);
            $('#editUsersFileModalLabel').text('Edit - ' + editUsersView.currentFile());
            $('#editUsersFileModalBody').val(data.content || '');
            editUsersView.clearValidation();
            $('#editUsersFileModal').modal('show');
        }).fail(function(xhr) {
            alert('Unable to load file for edit: ' + (xhr.responseText || xhr.statusText));
        });
    };

    editUsersView.validateContent = function(content, onValid) {
        $.ajax({
            url: this.apiUrl('/_sish/api/editusers/validate'),
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ content: content }),
            success: function() {
                editUsersView.showValidation('YAML is valid.', true);
                if (onValid) {
                    onValid();
                }
            },
            error: function(xhr) {
                editUsersView.showValidation('Invalid YAML: ' + (xhr.responseText || xhr.statusText), false);
            }
        });
    };

    editUsersView.validateCurrentFile = function() {
        this.validateContent($('#editUsersFileModalBody').val());
    };

    editUsersView.saveCurrentFile = function() {
        var filePath = this.currentFile();
        if (!filePath) {
            return;
        }

        var content = $('#editUsersFileModalBody').val();
        this.validateContent(content, function() {
            $.ajax({
                url: editUsersView.apiUrl('/_sish/api/editusers/file'),
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    file: filePath,
                    content: content
                }),
                success: function() {
                    $('#editUsersFileModal').modal('hide');
                    editUsersView.loadFiles();
                },
                error: function(xhr) {
                    editUsersView.showValidation('Unable to save file: ' + (xhr.responseText || xhr.statusText), false);
                }
            });
        });
    };

    $(function() {
        ko.applyBindings(editUsersView);
        editUsersView.loadFiles();
    });
</script>
{{ template "footer" .}}
{{ end }}
