{{ define "editkeys" }}
{{ template "header" .}}
<div class="row">
    <div class="col table-responsive">
        <h2>Edit Authentication Public Keys</h2>
        <p>Directory: <code data-bind="text: keysDirectory"></code></p>
        <table id="editkeys-table" class="table table-hover">
            <thead class="thead-dark">
                <tr>
                    <th scope="col">File</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody data-bind="foreach: files">
                <tr>
                    <td data-bind="text: $data"></td>
                    <td>
                        <a style="text-transform: none; color: white;" class="btn btn-info btn-sm mr-2" href="javascript:void(0);" data-bind="click: function(){ $root.viewFile($data); }">View</a>
                        <a style="text-transform: none; color: white;" class="btn btn-primary btn-sm" href="javascript:void(0);" data-bind="click: function(){ $root.editFile($data); }">Edit</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="viewFileModal" tabindex="-1" role="dialog" aria-labelledby="viewFileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewFileModalLabel">View File</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <pre id="viewFileModalBody" class="mb-0" style="white-space: pre-wrap;"></pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editFileModal" tabindex="-1" role="dialog" aria-labelledby="editFileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editFileModalLabel">Edit File</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <textarea id="editFileModalBody" class="form-control" rows="18" style="font-family: monospace;"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" data-bind="click: saveCurrentFile">Save</button>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var editKeysView = {
        files: ko.observableArray([]),
        keysDirectory: ko.observable(''),
        currentFile: ko.observable('')
    };

    editKeysView.getToken = function() {
        var params = new URLSearchParams(window.location.search);
        return params.get('x-authorization') || '';
    };

    editKeysView.apiUrl = function(path) {
        var token = this.getToken();
        if (!token) {
            return path;
        }

        var separator = path.indexOf('?') === -1 ? '?' : '&';
        return path + separator + 'x-authorization=' + encodeURIComponent(token);
    };

    editKeysView.loadFiles = function() {
        $.getJSON(this.apiUrl('/_sish/api/editkeys/files'), function(data) {
            editKeysView.files.removeAll();
            for (var i = 0; i < data.files.length; i++) {
                editKeysView.files.push(data.files[i]);
            }
            editKeysView.keysDirectory(data.keysDirectory || '');
        }).fail(function(xhr) {
            alert('Unable to load files: ' + (xhr.responseText || xhr.statusText));
        });
    };

    editKeysView.viewFile = function(filePath) {
        $.getJSON(this.apiUrl('/_sish/api/editkeys/file?file=' + encodeURIComponent(filePath)), function(data) {
            $('#viewFileModalLabel').text('View - ' + data.file);
            $('#viewFileModalBody').text(data.content || '');
            $('#viewFileModal').modal('show');
        }).fail(function(xhr) {
            alert('Unable to load file: ' + (xhr.responseText || xhr.statusText));
        });
    };

    editKeysView.editFile = function(filePath) {
        $.getJSON(this.apiUrl('/_sish/api/editkeys/file?file=' + encodeURIComponent(filePath)), function(data) {
            editKeysView.currentFile(data.file || filePath);
            $('#editFileModalLabel').text('Edit - ' + editKeysView.currentFile());
            $('#editFileModalBody').val(data.content || '');
            $('#editFileModal').modal('show');
        }).fail(function(xhr) {
            alert('Unable to load file for edit: ' + (xhr.responseText || xhr.statusText));
        });
    };

    editKeysView.saveCurrentFile = function() {
        var filePath = this.currentFile();
        if (!filePath) {
            return;
        }

        $.ajax({
            url: this.apiUrl('/_sish/api/editkeys/file'),
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                file: filePath,
                content: $('#editFileModalBody').val()
            }),
            success: function() {
                $('#editFileModal').modal('hide');
                editKeysView.loadFiles();
            },
            error: function(xhr) {
                alert('Unable to save file: ' + (xhr.responseText || xhr.statusText));
            }
        });
    };

    $(function() {
        ko.applyBindings(editKeysView);
        editKeysView.loadFiles();
    });
</script>
{{ template "footer" .}}
{{ end }}
