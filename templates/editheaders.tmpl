{{ define "editheaders" }}
{{ template "header" .}}
<div class="row">
    <div class="col table-responsive">
        <h2>Edit Headers Settings YAML</h2>
        <p>Directory: <code data-bind="text: headersDirectory"></code></p>
        <table id="editheaders-table" class="table table-hover">
            <thead class="thead-dark">
                <tr>
                    <th scope="col">File</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody data-bind="foreach: files">
                <tr>
                    <td data-bind="text: $data"></td>
                    <td>
                        <a style="text-transform: none; color: white;" class="btn btn-info btn-sm mr-2" href="javascript:void(0);" data-bind="click: function(){ $root.viewFile($data); }">View</a>
                        <a style="text-transform: none; color: white;" class="btn btn-primary btn-sm" href="javascript:void(0);" data-bind="click: function(){ $root.editFile($data); }">Edit</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="viewHeadersFileModal" tabindex="-1" role="dialog" aria-labelledby="viewHeadersFileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewHeadersFileModalLabel">View File</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <pre id="viewHeadersFileModalBody" class="mb-0" style="white-space: pre-wrap;"></pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editHeadersFileModal" tabindex="-1" role="dialog" aria-labelledby="editHeadersFileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editHeadersFileModalLabel">Edit File</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="editHeadersValidationResult" class="alert d-none" role="alert"></div>
                <textarea id="editHeadersFileModalBody" class="form-control" rows="18" style="font-family: monospace;"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-info" data-bind="click: validateCurrentFile">Validate</button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" data-bind="click: saveCurrentFile">Save</button>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var editHeadersView = {
        files: ko.observableArray([]),
        headersDirectory: ko.observable(''),
        currentFile: ko.observable('')
    };

    editHeadersView.getToken = function() {
        var params = new URLSearchParams(window.location.search);
        return params.get('x-authorization') || '';
    };

    editHeadersView.apiUrl = function(path) {
        var token = this.getToken();
        if (!token) {
            return path;
        }

        var separator = path.indexOf('?') === -1 ? '?' : '&';
        return path + separator + 'x-authorization=' + encodeURIComponent(token);
    };

    editHeadersView.showValidation = function(message, isValid) {
        var box = $('#editHeadersValidationResult');
        box.removeClass('d-none alert-success alert-danger');
        box.addClass(isValid ? 'alert-success' : 'alert-danger');
        box.text(message);
    };

    editHeadersView.clearValidation = function() {
        $('#editHeadersValidationResult').addClass('d-none').removeClass('alert-success alert-danger').text('');
    };

    editHeadersView.loadFiles = function() {
        $.getJSON(this.apiUrl('/_sish/api/editheaders/files'), function(data) {
            editHeadersView.files.removeAll();
            for (var i = 0; i < data.files.length; i++) {
                editHeadersView.files.push(data.files[i]);
            }
            editHeadersView.headersDirectory(data.headersDirectory || '');
        }).fail(function(xhr) {
            alert('Unable to load files: ' + (xhr.responseText || xhr.statusText));
        });
    };

    editHeadersView.viewFile = function(filePath) {
        $.getJSON(this.apiUrl('/_sish/api/editheaders/file?file=' + encodeURIComponent(filePath)), function(data) {
            $('#viewHeadersFileModalLabel').text('View - ' + data.file);
            $('#viewHeadersFileModalBody').text(data.content || '');
            $('#viewHeadersFileModal').modal('show');
        }).fail(function(xhr) {
            alert('Unable to load file: ' + (xhr.responseText || xhr.statusText));
        });
    };

    editHeadersView.editFile = function(filePath) {
        $.getJSON(this.apiUrl('/_sish/api/editheaders/file?file=' + encodeURIComponent(filePath)), function(data) {
            editHeadersView.currentFile(data.file || filePath);
            $('#editHeadersFileModalLabel').text('Edit - ' + editHeadersView.currentFile());
            $('#editHeadersFileModalBody').val(data.content || '');
            editHeadersView.clearValidation();
            $('#editHeadersFileModal').modal('show');
        }).fail(function(xhr) {
            alert('Unable to load file for edit: ' + (xhr.responseText || xhr.statusText));
        });
    };

    editHeadersView.validateContent = function(content, onValid) {
        $.ajax({
            url: this.apiUrl('/_sish/api/editheaders/validate'),
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ content: content }),
            success: function() {
                editHeadersView.showValidation('YAML is valid.', true);
                if (onValid) {
                    onValid();
                }
            },
            error: function(xhr) {
                editHeadersView.showValidation('Invalid YAML: ' + (xhr.responseText || xhr.statusText), false);
            }
        });
    };

    editHeadersView.validateCurrentFile = function() {
        this.validateContent($('#editHeadersFileModalBody').val());
    };

    editHeadersView.saveCurrentFile = function() {
        var filePath = this.currentFile();
        if (!filePath) {
            return;
        }

        var content = $('#editHeadersFileModalBody').val();
        this.validateContent(content, function() {
            $.ajax({
                url: editHeadersView.apiUrl('/_sish/api/editheaders/file'),
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    file: filePath,
                    content: content
                }),
                success: function() {
                    $('#editHeadersFileModal').modal('hide');
                    editHeadersView.loadFiles();
                },
                error: function(xhr) {
                    editHeadersView.showValidation('Unable to save file: ' + (xhr.responseText || xhr.statusText), false);
                }
            });
        });
    };

    $(function() {
        ko.applyBindings(editHeadersView);
        editHeadersView.loadFiles();
    });
</script>
{{ template "footer" .}}
{{ end }}
