{{ define "editcensus" }}
{{ template "header" .}}
<div class="row">
    <div class="col table-responsive">
        <h2>Edit Census YAML Files</h2>
        <p>Directory: <code data-bind="text: censusDirectory"></code></p>
        <table id="editcensus-table" class="table table-hover">
            <thead class="thead-dark">
                <tr>
                    <th scope="col">File</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody data-bind="foreach: files">
                <tr>
                    <td data-bind="text: $data"></td>
                    <td>
                        <a style="text-transform: none; color: white;" class="btn btn-info btn-sm mr-2" href="javascript:void(0);" data-bind="click: function(){ $root.viewFile($data); }">View</a>
                        <a style="text-transform: none; color: white;" class="btn btn-primary btn-sm" href="javascript:void(0);" data-bind="click: function(){ $root.editFile($data); }">Edit</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="viewCensusFileModal" tabindex="-1" role="dialog" aria-labelledby="viewCensusFileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewCensusFileModalLabel">View File</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <pre id="viewCensusFileModalBody" class="mb-0" style="white-space: pre-wrap;"></pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editCensusFileModal" tabindex="-1" role="dialog" aria-labelledby="editCensusFileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editCensusFileModalLabel">Edit File</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="editCensusValidationResult" class="alert d-none" role="alert"></div>
                <textarea id="editCensusFileModalBody" class="form-control" rows="18" style="font-family: monospace;"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-info" data-bind="click: validateCurrentFile">Validate</button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" data-bind="click: saveCurrentFile">Save</button>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var editCensusView = {
        files: ko.observableArray([]),
        censusDirectory: ko.observable(''),
        currentFile: ko.observable('')
    };

    editCensusView.getToken = function() {
        var params = new URLSearchParams(window.location.search);
        return params.get('x-authorization') || '';
    };

    editCensusView.apiUrl = function(path) {
        var token = this.getToken();
        if (!token) {
            return path;
        }

        var separator = path.indexOf('?') === -1 ? '?' : '&';
        return path + separator + 'x-authorization=' + encodeURIComponent(token);
    };

    editCensusView.showValidation = function(message, isValid) {
        var box = $('#editCensusValidationResult');
        box.removeClass('d-none alert-success alert-danger');
        box.addClass(isValid ? 'alert-success' : 'alert-danger');
        box.text(message);
    };

    editCensusView.clearValidation = function() {
        $('#editCensusValidationResult').addClass('d-none').removeClass('alert-success alert-danger').text('');
    };

    editCensusView.loadFiles = function() {
        $.getJSON(this.apiUrl('/_sish/api/editcensus/files'), function(data) {
            editCensusView.files.removeAll();
            for (var i = 0; i < data.files.length; i++) {
                editCensusView.files.push(data.files[i]);
            }
            editCensusView.censusDirectory(data.censusDirectory || '');
        }).fail(function(xhr) {
            alert('Unable to load files: ' + (xhr.responseText || xhr.statusText));
        });
    };

    editCensusView.viewFile = function(filePath) {
        $.getJSON(this.apiUrl('/_sish/api/editcensus/file?file=' + encodeURIComponent(filePath)), function(data) {
            $('#viewCensusFileModalLabel').text('View - ' + data.file);
            $('#viewCensusFileModalBody').text(data.content || '');
            $('#viewCensusFileModal').modal('show');
        }).fail(function(xhr) {
            alert('Unable to load file: ' + (xhr.responseText || xhr.statusText));
        });
    };

    editCensusView.editFile = function(filePath) {
        $.getJSON(this.apiUrl('/_sish/api/editcensus/file?file=' + encodeURIComponent(filePath)), function(data) {
            editCensusView.currentFile(data.file || filePath);
            $('#editCensusFileModalLabel').text('Edit - ' + editCensusView.currentFile());
            $('#editCensusFileModalBody').val(data.content || '');
            editCensusView.clearValidation();
            $('#editCensusFileModal').modal('show');
        }).fail(function(xhr) {
            alert('Unable to load file for edit: ' + (xhr.responseText || xhr.statusText));
        });
    };

    editCensusView.validateContent = function(content, onValid) {
        $.ajax({
            url: this.apiUrl('/_sish/api/editcensus/validate'),
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ content: content }),
            success: function() {
                editCensusView.showValidation('YAML is valid.', true);
                if (onValid) {
                    onValid();
                }
            },
            error: function(xhr) {
                editCensusView.showValidation('Invalid YAML: ' + (xhr.responseText || xhr.statusText), false);
            }
        });
    };

    editCensusView.validateCurrentFile = function() {
        this.validateContent($('#editCensusFileModalBody').val());
    };

    editCensusView.saveCurrentFile = function() {
        var filePath = this.currentFile();
        if (!filePath) {
            return;
        }

        var content = $('#editCensusFileModalBody').val();
        this.validateContent(content, function() {
            $.ajax({
                url: editCensusView.apiUrl('/_sish/api/editcensus/file'),
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    file: filePath,
                    content: content
                }),
                success: function() {
                    $('#editCensusFileModal').modal('hide');
                    editCensusView.loadFiles();
                },
                error: function(xhr) {
                    editCensusView.showValidation('Unable to save file: ' + (xhr.responseText || xhr.statusText), false);
                }
            });
        });
    };

    $(function() {
        ko.applyBindings(editCensusView);
        editCensusView.loadFiles();
    });
</script>
{{ template "footer" .}}
{{ end }}
