# TCP tunnel on fixed remote port
SSH_HOST=tuns.0912345.xyz
SSH_PORT=2222
SSH_USER=alpha
SSH_AUTH_MODE=auto
SSH_STRICT_HOST_KEY_CHECKING=no
SSH_USER_KNOWN_HOSTS_FILE=/tmp/ssh_known_hosts
SSH_SERVER_ALIVE_INTERVAL=30
SSH_SERVER_ALIVE_COUNT_MAX=3
SSH_CONNECT_TIMEOUT=10
SSH_EXIT_ON_FORWARD_FAILURE=yes
SSH_REMOTE_FORWARDS=9001:localhost:9001
SISH_ID=tcp-9001
SISH_NOTE=TCP tunnel on 9001
